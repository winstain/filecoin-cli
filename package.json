{
  "name": "filecoin-cli",
  "version": "1.0.0",
  "description": "Agent-first CLI for Filecoin storage and IPFS. JSON output by default.",
  "main": "dist/index.js",
  "bin": {
    "filecoin": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "jest --runInBand --verbose --testPathPatterns=tests/unit",
    "test:coverage": "jest --runInBand --coverage --testPathPatterns=tests/unit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "filecoin",
    "ipfs",
    "storage",
    "cli"
  ],
  "author": "winstain",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "chalk": "^4.1.2",
    "commander": "^14.0.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/winstain/filecoin-cli.git"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
